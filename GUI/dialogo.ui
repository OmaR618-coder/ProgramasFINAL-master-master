   <string notr="true">/* Fondo general */
QWidget {
    background-color: #1e1e2f;
    color: #eaeaf0;
    font-family: 'Segoe UI', 'Roboto', sans-serif;
    font-size: 10pt;
}

/* Botones */
QPushButton {
    background-color: #3a3f58;
    border-radius: 8px;
    padding: 8px 16px;
    color: white;
}

QPushButton:hover {
    background-color: #50577a;
}

QPushButton:pressed {
    background-color: #2c2f45;
}

/* Inputs */
QLineEdit, QTextEdit {
    background-color: #2a2d3e;
    border: 1px solid #3f445e;
    border-radius: 6px;
    padding: 6px;
}

/* Labels */
QLabel {
    color: #cfd3ff;
    font-weight: 500;
}

/* ComboBox */
QComboBox {
    background-color: #2a2d3e;
    border-radius: 6px;
    padding: 5px;
}

/* Barra de menú */
QMenuBar {
    background-color: #2a2d3e;
}

QMenuBar::item:selected {
    background-color: #3f445e;
}

/* Tabs */
QTabWidget::pane {
    border: 1px solid #3f445e;
}

QTabBar::tab {
    background: #2a2d3e;
    padding: 8px;
}

QTabBar::tab:selected {
    background: #3f445e;
}</string>
