  <property name="styleSheet">
   <string notr="true">/* Configuración General */
QMainWindow {
    background-color: #F0F4F8; /* Gris muy claro azulado */
}

QWidget {
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 18px; /* Fuente grande */
    color: #4A4A4A;
}

/* Barra de Menú */
QMenuBar {
    background-color: #FFDEE9; /* Rosa pastel */
    border-bottom: 2px solid #B5FFFC; /* Línea turquesa */
    padding: 5px;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 15px;
    margin: 2px;
    border-radius: 5px;
}

QMenuBar::item:selected {
    background-color: #B5FFFC; /* Turquesa pastel al seleccionar */
    color: #2D5F5D;
}

/* Menús Desplegables */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #FFDEE9;
    padding: 10px;
}

QMenu::item {
    padding: 8px 30px 8px 20px;
    border-radius: 4px;
    margin: 3px;
}

QMenu::item:selected {
    background-color: #E2EBFF; /* Azul pastel suave */
    color: #4A90E2;
}

/* Separadores dentro del menú */
QMenu::separator {
    height: 2px;
    background: #F0F0F0;
    margin: 5px 10px;
}

/* Acciones (QAction se hereda de QMenu::item) */
/* Nota: Las acciones no se estilizan directamente por clase, 
sino a través de su contenedor QMenu */</string>
